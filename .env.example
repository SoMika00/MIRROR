# xAI Grok API (chat completions)
GROK_API_KEY=xai-your-key-here
GROK_MODEL=grok-4.20-non-reasoning
GROK_BASE_URL=https://api.x.ai/v1
GROK_DAILY_BUDGET=0.50
# Pricing in USD per 1M tokens (used for budget accounting)
GROK_INPUT_PRICE=1.25
GROK_OUTPUT_PRICE=2.50

# Optional: embeddings via an OpenAI-compatible API (hybrid retrieval).
# Leave EMBEDDINGS_API_KEY empty to use pure BM25 (SQLite FTS5) retrieval.
# xAI does not expose an embeddings endpoint yet; when it does, set the key.
EMBEDDINGS_API_KEY=
EMBEDDINGS_API_BASE=https://api.x.ai/v1
EMBEDDINGS_MODEL=grok-embedding

# App Configuration
FLASK_DEBUG=0
SECRET_KEY=change-me-in-production-use-random-string
UPLOAD_FOLDER=./uploads
ARTICLES_FOLDER=./articles
MAX_CONTENT_LENGTH=16777216
