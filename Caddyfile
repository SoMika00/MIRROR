mymirror.fr {
    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # PaperClue app (separate stack, its web container joins this docker network)
    handle /paperclue* {
        reverse_proxy paperclue-web:3000
    }

    handle {
        reverse_proxy mirror:5000
    }
}

www.mymirror.fr {
    redir https://mymirror.fr{uri} permanent
}

http://51.83.71.145 {
    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    handle /paperclue* {
        reverse_proxy paperclue-web:3000
    }

    handle {
        reverse_proxy mirror:5000
    }
}
